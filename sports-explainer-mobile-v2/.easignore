# .easignore — used by EAS Build INSTEAD of .gitignore when present.
# Mirrors the repo .gitignore, EXCEPT it intentionally does NOT ignore
# *.png, so the app icon and splash assets get uploaded to the build.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# media — NOTE: *.png intentionally NOT ignored (needed for app icon/splash)
*.mov
*.mp4
Images/
Documentation/
Documentation/*.pdf
chrome-extension/Icon128.png
sports-explainer-v1.zip
